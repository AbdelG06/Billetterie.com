{
  "buildCommand": "echo 'No build required for static site'",
  "public": ".",
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/images/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/:path*.{js,css,json}",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
